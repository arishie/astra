{
  "name": "astra",
  "version": "1.0.0",
  "description": "Self-hosted AI assistant for WhatsApp & Telegram",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:api": "node dist/api/server.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:security": "vitest run tests/security",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "migrate": "node dist/database/MigrationRunner.js",
    "migrate:status": "node dist/database/MigrationRunner.js status",
    "migrate:run": "node dist/database/MigrationRunner.js run",
    "migrate:create": "node dist/database/MigrationRunner.js create",
    "db:setup": "npm run build && npm run migrate:run",
    "healthcheck": "node dist/startup/HealthCheck.js",
    "prestart": "npm run healthcheck || true",
    "prestart:api": "npm run healthcheck || true"
  },
  "keywords": [
    "ai",
    "agent",
    "chatbot",
    "multi-tenant",
    "saas"
  ],
  "author": "Astra Project Contributors",
  "license": "SEE LICENSE FILE",
  "homepage": "https://github.com/astra-ai/astra",
  "repository": {
    "type": "git",
    "url": "https://github.com/astra-ai/astra.git"
  },
  "bugs": {
    "url": "https://github.com/astra-ai/astra/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.19.13",
    "@types/pg": "^8.11.6",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/screenshot-desktop": "^1.15.0",
    "@vitest/coverage-v8": "^2.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.31",
    "@ai-sdk/google": "^3.0.18",
    "@ai-sdk/openai": "^3.0.23",
    "@lancedb/lancedb": "^0.23.0",
    "@langchain/community": "^1.1.9",
    "@langchain/core": "^1.1.17",
    "@slack/bolt": "^4.6.0",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "@xenova/transformers": "^2.17.2",
    "ai": "^6.0.62",
    "apache-arrow": "^18.1.0",
    "chokidar": "^5.0.0",
    "chromadb": "^3.2.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "discord.js": "^14.25.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.0",
    "helmet": "^7.1.0",
    "jimp": "^1.6.0",
    "jose": "^5.6.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.12.0",
    "pino": "^10.3.0",
    "playwright": "^1.58.1",
    "qrcode-terminal": "^0.12.0",
    "redis": "^4.7.0",
    "robotjs": "^0.6.0",
    "screenshot-desktop": "^1.15.3",
    "systeminformation": "^5.30.6",
    "telegraf": "^4.16.3",
    "uuid": "^13.0.0"
  }
}
