# Astra AI Agent Framework - Environment Configuration
# Copy this file to .env and fill in the values

# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=3000

# ============================================
# DATABASE (PostgreSQL)
# ============================================
DATABASE_URL=postgres://astra:astra@localhost:5432/astra
# Or individual settings:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=astra
# DB_USER=astra
# DB_PASSWORD=astra
# DB_SSL=false

# ============================================
# REDIS (for rate limiting & sessions)
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# SECURITY (REQUIRED - Generate unique values!)
# ============================================
# Generate with: openssl rand -hex 32
MASTER_ENCRYPTION_KEY=your-32-character-minimum-encryption-key-here
JWT_SECRET=your-32-character-minimum-jwt-secret-here
JWT_REFRESH_SECRET=your-32-character-minimum-refresh-secret-here
SYSTEM_SECRET=your-32-character-minimum-system-secret-here

# Token expiration
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ============================================
# OAUTH PROVIDERS
# ============================================
# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Apple Sign In (https://developer.apple.com/account/resources/identifiers/list)
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# OAuth callback URL (change for production)
OAUTH_REDIRECT_URI=http://localhost:3000/api/v1/auth/callback

# ============================================
# MESSAGING PLATFORMS (Bot Tokens)
# ============================================
# Telegram Bot (@BotFather)
TELEGRAM_BOT_TOKEN=

# Discord Bot (https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=

# Slack App (https://api.slack.com/apps)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=

# WhatsApp Business API (optional - for official API mode)
WHATSAPP_BUSINESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ============================================
# LLM PROVIDERS (System defaults - users provide their own)
# ============================================
# OpenAI (for system operations if needed)
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Google AI
GOOGLE_AI_API_KEY=

# ============================================
# PYTHON ENGINE
# ============================================
ENGINE_URL=http://localhost:8000
AGENTOPS_API_KEY=

# ============================================
# OPTIONAL SERVICES
# ============================================
# ElevenLabs (Voice)
ELEVENLABS_API_KEY=

# Twilio (SMS Bridge)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ============================================
# MONITORING & LOGGING
# ============================================
LOG_LEVEL=info
# Sentry (Error tracking)
SENTRY_DSN=

# ============================================
# DOCKER SANDBOX
# ============================================
# Default sandbox mode: docker, host, or mock
SANDBOX_MODE=docker
SANDBOX_MEMORY_LIMIT=256m
SANDBOX_CPU_LIMIT=0.5
SANDBOX_TIMEOUT=30000
